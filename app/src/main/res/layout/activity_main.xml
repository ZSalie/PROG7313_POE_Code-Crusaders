<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/teal_background_full"
    android:clipToPadding="false"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="48dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_white_card"
            android:elevation="4dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create new&#10;Account"
                    android:textSize="32sp"
                    android:textColor="#000000"
                    android:fontFamily="@font/poppins_bold"/>

                <LinearLayout
                    android:id="@+id/llLoginPrompt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already Registered? "
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:fontFamily="@font/poppins_regular" />

                    <TextView
                        android:id="@+id/tvLoginLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log in here"
                        android:textSize="12sp"
                        android:textColor="#096666"
                        android:fontFamily="@font/poppins_bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/labelName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="NAME"
                    android:textSize="12sp"
                    android:textColorHint="#555555"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/poppins_regular"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:hint="User name"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:textColor="#000000"
                    android:textColorHint="#9E9E9E"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="textPersonName"/>

                <TextView
                    android:id="@+id/labelEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EMAIL"
                    android:textSize="12sp"
                    android:textColorHint="#555555"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/poppins_regular"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:hint="name@example.com"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:textColor="#000000"
                    android:textColorHint="#9E9E9E"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="textEmailAddress"/>

                <TextView
                    android:id="@+id/labelPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="PASSWORD"
                    android:textSize="12sp"
                    android:textColorHint="#555555"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/poppins_regular"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:hint="******"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:textColorHint="#9E9E9E"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="textPassword"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/bg_button"
                    android:text="Sign up"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>